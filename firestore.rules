rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Events collection
    match /events/{eventId} {
      allow read: if true; // Public events - allow read
      allow write: if false; // Admin only - not implemented yet
    }

    // TicketTypes collection
    match /events/{eventId}/ticketTypes/{ticketTypeId} {
      allow read: if true;
      allow write: if false;
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read, create, update, delete: if true;
    }
  }
}
