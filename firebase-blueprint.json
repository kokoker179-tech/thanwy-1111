{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "An event being held",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "date", "location"]
    },
    "TicketType": {
      "title": "Ticket Type",
      "description": "A type of ticket for an event",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "eventId": { "type": "string" }
      },
      "required": ["name", "price", "eventId"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A user's booking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "year": { "type": "string" },
        "gender": { "type": "string" },
        "phone": { "type": "string" },
        "eventId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "year", "gender", "phone", "eventId", "createdAt"]
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Stores event information"
    },
    "/events/{eventId}/ticketTypes/{ticketTypeId}": {
      "schema": "TicketType",
      "description": "Stores ticket types for an event"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Stores user bookings"
    }
  }
}
